# ============================================================================
# ops-dashboard — environment variables (template)
# Copy to .env.local for local dev; set the same keys in Vercel → Settings →
# Environment Variables for production. NEVER commit real values.
#
# To confirm this list is complete against the code, run:
#   grep -rhoE "process\.env\.[A-Z_]+" app lib components | sort -u
# ============================================================================

# --- Auth (NextAuth v4, Google OAuth restricted to @nextventures.io) ---
# NOTE: confirm the exact names against lib/auth.ts — NextAuth v4 commonly uses:
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=            # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Supabase (server-side only; service role key must never reach the client) ---
SUPABASE_URL=https://yzovmcbjovejmpwluxog.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Intercom (TEEP data) ---
INTERCOM_ACCESS_TOKEN=      # raw token, NO "Bearer " prefix

# --- Google Sheets (BizOps/CR metrics for Daily Huddle / BD-SL) ---
GOOGLE_CREDENTIALS_JSON=    # full service-account JSON, single line

# --- ClickUp (OPS Process Update feed) ---
CLICKUP_API_TOKEN=          # personal token, starts with pk_
CLICKUP_WORKSPACE_ID=3480971
CLICKUP_CHANNEL_ID=3a7cb-362458

# ============================================================================
# BI server (172.16.110.170) — separate .env in the sync folder, NOT this repo:
#   /srv/samba/myshare/supabase-ops-dashboard/.env
#     INTERCOM_ACCESS_TOKEN=...
#     SUPABASE_URL=...
#     SUPABASE_SERVICE_ROLE_KEY=...
# ============================================================================
